// FactionGuilds Menu - Main Hub Page
// Uses centralized Styles.ui and NavBar.ui

$C = "../Common.ui";
$S = "Styles.ui";

$C.@PageOverlay {
  Group {
    Anchor: (Width: 750, Height: 520);
    Background: #0a1119(0.98);
    LayoutMode: Top;

    // === Navigation Bar ===
    Group {
      Anchor: (Height: 45);
      Background: #16212f;
      LayoutMode: Left;

      Group {
        Anchor: (Width: 180, Height: 45);
        LayoutMode: Left;
        Padding: (Left: 16);

        Label {
          Text: "Factions";
          Style: (FontSize: 18, TextColor: #4FC3F7, RenderBold: true, VerticalAlignment: Center);
        }
      }

      Group {
        Anchor: (Width: 1, Top: 8, Bottom: 8);
        Background: #2b3542;
      }

      Group { FlexWeight: 1; }

      Group {
        LayoutMode: Left;
        Padding: (Right: 12);

        TextButton #CloseButton {
          Text: "X";
          Anchor: (Width: 36, Height: 36);
          Style: TextButtonStyle(
            Default: (Background: #000000(0), LabelStyle: (FontSize: 16, TextColor: #7c8b99, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
            Hovered: (Background: #8b3a3a, LabelStyle: (FontSize: 16, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
            Pressed: (Background: #7b2a2a, LabelStyle: (FontSize: 16, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
            Sounds: $C.@ButtonSounds,
          );
        }
      }
    }

    // === Main Content ===
    Group {
      FlexWeight: 1;
      LayoutMode: Top;
      Padding: (Left: 24, Right: 24, Top: 16, Bottom: 16);

      // Player Header Row
      Group #PlayerHeader {
        Anchor: (Height: 50, Bottom: 12);
        LayoutMode: Left;

        Label #FactionTag {
          Text: "[???]";
          Style: (FontSize: 22, TextColor: #96a9be, RenderBold: true, VerticalAlignment: Center);
        }

        Group {
          LayoutMode: Top;
          Padding: (Left: 12);

          Label #PlayerName {
            Text: "Player";
            Anchor: (Height: 26);
            Style: (FontSize: 18, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
          }

          Label #GuildName {
            Text: "No Guild";
            Anchor: (Height: 20);
            Style: (FontSize: 13, TextColor: #96a9be, RenderBold: false, VerticalAlignment: Center);
          }
        }
      }

      // Stats Row
      Group #StatsSection {
        Anchor: (Height: 70, Bottom: 16);
        LayoutMode: Left;

        Group #PowerStat {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Right: 4);

          Label {
            Text: "POWER";
            Style: (FontSize: 9, TextColor: #666666, RenderBold: false);
            Anchor: (Height: 14);
          }
          Label #PowerValue {
            Text: "0";
            Style: (FontSize: 20, TextColor: #4FC3F7, RenderBold: true);
            FlexWeight: 1;
          }
        }

        Group #RankStat {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Left: 4, Right: 4);

          Label {
            Text: "RANK";
            Style: (FontSize: 9, TextColor: #666666, RenderBold: false);
            Anchor: (Height: 14);
          }
          Label #RankValue {
            Text: "None";
            Style: (FontSize: 20, TextColor: #81C784, RenderBold: true);
            FlexWeight: 1;
          }
        }

        Group #InviteStat {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Left: 4);

          Label {
            Text: "INVITATIONS";
            Style: (FontSize: 9, TextColor: #666666, RenderBold: false);
            Anchor: (Height: 14);
          }
          Label #InviteCount {
            Text: "0";
            Style: (FontSize: 20, TextColor: #FFAA00, RenderBold: true);
            FlexWeight: 1;
          }
          Label {
            Text: "pending";
            Style: (FontSize: 9, TextColor: #444444, RenderBold: false);
            Anchor: (Height: 14);
          }
        }
      }

      // Separator
      Group {
        Anchor: (Height: 1, Bottom: 16);
        Background: #4FC3F7(0.3);
      }

      // Navigation Sections Row
      Group {
        Anchor: (Height: 130, Bottom: 16);
        LayoutMode: Left;

        // My Guild Section
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          LayoutMode: Top;
          Padding: (Full: 14);
          Anchor: (Right: 6);

          Label {
            Text: "MY GUILD";
            Anchor: (Height: 18, Bottom: 6);
            Style: (FontSize: 11, TextColor: #96a9be, RenderBold: true, LetterSpacing: 1);
          }

          TextButton #MyGuildButton {
            Text: "View Guild";
            Anchor: (Height: 30, Bottom: 4);
            Style: $S.@PrimaryButtonStyle;
          }

          TextButton #ManageMembersButton {
            Text: "Manage Members";
            Anchor: (Height: 30);
            Style: $S.@PrimaryButtonStyle;
          }
        }

        // Territory Section
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          LayoutMode: Top;
          Padding: (Full: 14);
          Anchor: (Left: 6, Right: 6);

          Label {
            Text: "TERRITORY";
            Anchor: (Height: 18, Bottom: 6);
            Style: (FontSize: 11, TextColor: #96a9be, RenderBold: true, LetterSpacing: 1);
          }

          TextButton #LandClaimsButton {
            Text: "Land Claims";
            Anchor: (Height: 30, Bottom: 4);
            Style: $S.@WarningButtonStyle;
          }

          TextButton #FactionOverviewButton {
            Text: "Faction Overview";
            Anchor: (Height: 30);
            Style: $S.@PrimaryButtonStyle;
          }
        }

        // Browse Section
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          LayoutMode: Top;
          Padding: (Full: 14);
          Anchor: (Left: 6);

          Label {
            Text: "SOCIAL";
            Anchor: (Height: 18, Bottom: 6);
            Style: (FontSize: 11, TextColor: #96a9be, RenderBold: true, LetterSpacing: 1);
          }

          TextButton #BrowseGuildsButton {
            Text: "Browse Guilds";
            Anchor: (Height: 30, Bottom: 4);
            Style: $S.@PrimaryButtonStyle;
          }

          TextButton #InvitationsButton {
            Text: "Invitations";
            Anchor: (Height: 30);
            Style: $S.@PrimaryButtonStyle;
          }
        }
      }

      // Create Guild Section (when not in a guild)
      Group #CreateGuildSection {
        Anchor: (Height: 100);
        LayoutMode: Top;
        Background: (Color: #1a2a3a);
        Padding: (Full: 14);
        Visible: true;

        Label {
          Text: "CREATE A GUILD";
          Anchor: (Height: 18, Bottom: 8);
          Style: (FontSize: 11, TextColor: #96a9be, RenderBold: true, LetterSpacing: 1);
        }

        Group {
          LayoutMode: Left;
          Anchor: (Height: 40);

          TextField #GuildNameInput {
            FlexWeight: 1;
            Anchor: (Height: 34);
            PlaceholderText: "Enter guild name...";
            Style: $S.@InputFieldStyle;
            PlaceholderStyle: $S.@InputPlaceholderStyle;
            Background: #0a1119;
            Padding: (Horizontal: 10);
          }

          Group { Anchor: (Width: 8); }

          Group {
            Anchor: (Width: 100);
            LayoutMode: Top;

            Label {
              Text: "TAG (1-4 letters)";
              Anchor: (Height: 12);
              Style: (FontSize: 8, TextColor: #96a9be, RenderBold: false, HorizontalAlignment: Center);
            }

            TextField #GuildTagInput {
              Anchor: (Height: 22);
              PlaceholderText: "TAG";
              Style: $S.@InputFieldStyle;
              PlaceholderStyle: $S.@InputPlaceholderStyle;
              Background: #0a1119;
              Padding: (Horizontal: 6);
            }
          }

          Group { Anchor: (Width: 8); }

          TextButton #CreateGuildButton {
            Text: "CREATE";
            Anchor: (Width: 100, Height: 34);
            Style: $S.@SuccessButtonStyle;
          }
        }
      }

      // Leave Guild Section (when in a guild, not leader)
      Group #LeaveGuildSection {
        Anchor: (Height: 44);
        LayoutMode: Left;
        Visible: true;

        TextButton #LeaveGuildButton {
          Text: "LEAVE GUILD";
          Anchor: (Width: 160, Height: 36);
          Style: $S.@DangerButtonStyle;
        }
      }

      Group { FlexWeight: 1; }

      // Quick Info
      Group #QuickInfoSection {
        Anchor: (Height: 50);
        Background: #1b2532(0.3);
        Padding: (Left: 14, Right: 14, Top: 8, Bottom: 8);
        LayoutMode: Top;

        Label #QuickInfoText {
          Text: "Use the sections above to navigate. Create or join a guild to access all features.";
          FlexWeight: 1;
          Style: (FontSize: 12, TextColor: #666666, RenderBold: false);
        }
      }
    }
  }
}
