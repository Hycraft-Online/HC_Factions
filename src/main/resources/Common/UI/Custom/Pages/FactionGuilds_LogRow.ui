// Activity Log Row Template - Single log entry
// Appended to #LogList

$C = "../Common.ui";
$S = "Styles.ui";

Group {
  Anchor: (Height: 36, Bottom: 4);
  Background: #1a2a3a(0.6);
  LayoutMode: Left;
  Padding: (Left: 12, Right: 12, Top: 6, Bottom: 6);

  // Timestamp
  Label #LogTimestamp {
    Text: "00:00";
    Anchor: (Width: 100);
    Style: (FontSize: 11, TextColor: #666666, RenderBold: false, VerticalAlignment: Center);
  }

  // Color indicator dot
  Group #LogDot {
    Anchor: (Width: 6, Height: 6, Right: 8);
    Background: #96a9be;
  }

  // Actor name
  Label #LogActor {
    Text: "Player";
    Anchor: (Width: 120);
    Style: (FontSize: 12, TextColor: #96a9be, RenderBold: true, VerticalAlignment: Center);
  }

  // Event description
  Label #LogDescription {
    Text: "did something";
    FlexWeight: 1;
    Style: (FontSize: 12, TextColor: #96a9be, RenderBold: false, VerticalAlignment: Center);
  }
}
