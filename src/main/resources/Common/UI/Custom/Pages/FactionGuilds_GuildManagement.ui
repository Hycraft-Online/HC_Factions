$C = "../Common.ui";
$S = "Styles.ui";

// FactionGuilds Guild Management - NavBar layout with organized sections

$C.@PageOverlay {
  Group {
    Anchor: (Width: 900, Height: 600);
    Background: #0a1119(0.95);
    LayoutMode: Top;

    // NavBar at top
    Group #NavBarContainer {
      LayoutMode: Top;
    }

    // Main content below nav
    Group #ContentArea {
      FlexWeight: 1;
      Background: #141c26(0.98);
      LayoutMode: Top;
      Padding: (Left: 24, Right: 24, Top: 16, Bottom: 16);

      // Guild header
      Group #GuildHeader {
        Anchor: (Height: 50);
        LayoutMode: Left;

        Label #GuildNameLabel {
          Text: "Guild Name";
          FlexWeight: 1;
          Style: $S.@TitleLabelStyle;
        }

        Label #MemberCountLabel {
          Text: "0 members";
          Anchor: (Width: 140);
          Style: $S.@SubtitleLabelStyle;
        }
      }

      $S.@Separator {}

      // Invite section (officers+)
      Group #InviteSection {
        Anchor: (Height: 56, Top: 12);
        LayoutMode: Left;
        Visible: true;

        Label {
          Text: "INVITE PLAYER";
          Anchor: (Width: 110, Height: 36);
          Style: $S.@SectionHeaderStyle;
        }

        TextField #InvitePlayerName {
          Anchor: (Height: 36);
          FlexWeight: 1;
          PlaceholderText: "Enter player name...";
          Style: $S.@InputFieldStyle;
          PlaceholderStyle: $S.@InputPlaceholderStyle;
          Background: #1b2532;
          Padding: (Horizontal: 10);
        }

        Group { Anchor: (Width: 8); }

        TextButton #InviteButton {
          Text: "INVITE";
          Anchor: (Width: 90, Height: 36);
          Style: $S.@SuccessButtonStyle;
        }
      }

      // Join Requests section
      Group #JoinRequestsSection {
        LayoutMode: Top;
        Visible: false;
        Anchor: (Top: 8);

        Group {
          LayoutMode: Left;
          Anchor: (Height: 28);

          Label {
            Text: "JOIN REQUESTS";
            Anchor: (Width: 130, Height: 24);
            Style: $S.@SectionHeaderStyle;
          }

          Label #JoinRequestCount {
            Text: "";
            Anchor: (Height: 24);
            Style: (FontSize: 12, TextColor: #FFAA00, RenderBold: true, VerticalAlignment: Center);
          }
        }

        Group #JoinRequestsList {
          LayoutMode: Top;
        }

        $S.@SpacerSmall {}
      }

      // Members list header
      Group {
        Anchor: (Height: 28, Top: 4);
        LayoutMode: Left;

        Label {
          Text: "MEMBERS";
          Style: $S.@SectionHeaderStyle;
        }
      }

      $S.@SpacerSmall {}

      // Scrollable members list
      Group #MembersContainer {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;

        Group #MembersList {
          LayoutMode: Top;
          Padding: (Right: 12);
        }
      }

      // Bottom action bar
      Group #BottomActions {
        Anchor: (Height: 48, Top: 8);
        LayoutMode: Left;

        TextButton #ActivityLogButton {
          Text: "ACTIVITY LOG";
          Anchor: (Width: 140, Height: 38);
          Style: $S.@PrimaryButtonStyle;
        }

        Group { FlexWeight: 1; }

        TextButton #TransferLeadershipButton {
          Text: "TRANSFER LEADERSHIP";
          Anchor: (Width: 200, Height: 38);
          Style: $S.@WarningButtonStyle;
          Visible: true;
        }

        Group { Anchor: (Width: 10); }

        TextButton #DisbandGuildButton {
          Text: "DISBAND GUILD";
          Anchor: (Width: 160, Height: 38);
          Style: $S.@DangerButtonStyle;
          Visible: true;
        }
      }
    }
  }
}
