$C = "../Common.ui";
$S = "Styles.ui";

// FactionGuilds Faction Members - NavBar layout with member list

$C.@PageOverlay {
  Group {
    Anchor: (Width: 900, Height: 600);
    Background: #0a1119(0.95);
    LayoutMode: Top;

    // NavBar at top
    Group #NavBarContainer {
      LayoutMode: Top;
    }

    // Main content below nav
    Group #ContentArea {
      FlexWeight: 1;
      Background: #141c26(0.98);
      LayoutMode: Top;
      Padding: (Left: 24, Right: 24, Top: 16, Bottom: 16);

      // Faction header
      Group #FactionHeader {
        Anchor: (Height: 46);
        LayoutMode: Left;

        Label #FactionNameLabel {
          Text: "Faction Name";
          FlexWeight: 1;
          Style: $S.@TitleLabelStyle;
        }

        // Member count badge
        Group {
          Anchor: (Width: 120);
          LayoutMode: CenterMiddle;

          Label #MemberCountLabel {
            Text: "0 members";
            Style: (FontSize: 16, TextColor: #4FC3F7, RenderBold: true, VerticalAlignment: Center);
          }
        }
      }

      $S.@Separator {}
      $S.@SpacerSmall {}

      // Section header
      Group {
        Anchor: (Height: 24);
        LayoutMode: Left;

        Label {
          Text: "ALL MEMBERS";
          Style: $S.@SectionHeaderStyle;
        }
      }

      $S.@SpacerSmall {}

      // Scrollable members list
      Group #MembersContainer {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;

        Group #MembersList {
          LayoutMode: Top;
          Padding: (Right: 12);
        }
      }
    }
  }
}
