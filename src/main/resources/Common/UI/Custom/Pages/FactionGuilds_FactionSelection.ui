$C = "../Common.ui";
$S = "Styles.ui";

// Faction Selection UI - Full-screen centered layout for choosing faction allegiance

$C.@PageOverlay {

  // Centered container
  Group {
    Anchor: (Width: 800, Height: 540);
    Background: #0a1119(0.98);
    LayoutMode: Top;

    // Top accent bar
    Group {
      Anchor: (Height: 3);
      Background: #4FC3F7(0.5);
    }

    // Title area
    Group {
      Anchor: (Height: 70);
      LayoutMode: CenterMiddle;
      Padding: (Top: 12);

      Group {
        LayoutMode: Top;

        Label #TitleLabel {
          Text: "Choose Your Allegiance";
          Anchor: (Height: 36);
          Style: (FontSize: 26, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center);
        }

        Label #Subtitle {
          Text: "Your choice will shape your destiny";
          Anchor: (Height: 24);
          Style: (FontSize: 14, TextColor: #96a9be, RenderBold: false, HorizontalAlignment: Center);
        }
      }
    }

    $S.@Separator {}

    // Faction cards container
    Group #FactionsContainer {
      FlexWeight: 1;
      LayoutMode: Left;
      Padding: (Left: 24, Right: 24, Top: 16, Bottom: 12);

      // Valor Faction Card (left)
      Group #AllianceCard {
        FlexWeight: 1;
        LayoutMode: Top;
        Background: #141c26(0.95);
        Padding: (Full: 20);
        Anchor: (Right: 10);

        // Gold accent top border
        Group {
          Anchor: (Height: 3);
          Background: #D4AF37;
        }

        $S.@SpacerMedium {}

        Label #AllianceName {
          Text: "Kingdom of Valor";
          Anchor: (Height: 36, Bottom: 8);
          Style: (FontSize: 24, TextColor: #D4AF37, RenderBold: true, HorizontalAlignment: Center);
        }

        Label #AllianceDescription {
          Text: "Noble warriors who fight for honor, justice, and the protection of the innocent.";
          Anchor: (Height: 44, Bottom: 8);
          Style: (FontSize: 13, TextColor: #cccccc, RenderBold: false, HorizontalAlignment: Center);
        }

        Label #AllianceLore {
          Text: "\"Honor. Justice. Brotherhood.\"";
          Anchor: (Height: 22, Bottom: 12);
          Style: (FontSize: 12, TextColor: #96a9be, RenderBold: false, HorizontalAlignment: Center);
        }

        $S.@Separator {}

        $S.@SpacerSmall {}

        Label #AllianceMembers {
          Text: "0 members";
          Anchor: (Height: 24, Bottom: 16);
          Style: (FontSize: 14, TextColor: #4FC3F7, RenderBold: true, HorizontalAlignment: Center);
        }

        // Spacer
        Group { FlexWeight: 1; }

        TextButton #JoinValorButton {
          Text: "Join Valor";
          Anchor: (Height: 44);
          Style: $S.@ValorButtonStyle;
        }
      }

      // Iron Legion Faction Card (right)
      Group #HordeCard {
        FlexWeight: 1;
        LayoutMode: Top;
        Background: #141c26(0.95);
        Padding: (Full: 20);
        Anchor: (Left: 10);

        // Red accent top border
        Group {
          Anchor: (Height: 3);
          Background: #FF6B6B;
        }

        $S.@SpacerMedium {}

        Label #HordeName {
          Text: "The Iron Legion";
          Anchor: (Height: 36, Bottom: 8);
          Style: (FontSize: 24, TextColor: #FF6B6B, RenderBold: true, HorizontalAlignment: Center);
        }

        Label #HordeDescription {
          Text: "Masters of industry and warfare, forging their destiny through iron will.";
          Anchor: (Height: 44, Bottom: 8);
          Style: (FontSize: 13, TextColor: #cccccc, RenderBold: false, HorizontalAlignment: Center);
        }

        Label #HordeLore {
          Text: "\"Strength. Industry. Dominion.\"";
          Anchor: (Height: 22, Bottom: 12);
          Style: (FontSize: 12, TextColor: #96a9be, RenderBold: false, HorizontalAlignment: Center);
        }

        $S.@Separator {}

        $S.@SpacerSmall {}

        Label #HordeMembers {
          Text: "0 members";
          Anchor: (Height: 24, Bottom: 16);
          Style: (FontSize: 14, TextColor: #4FC3F7, RenderBold: true, HorizontalAlignment: Center);
        }

        // Spacer
        Group { FlexWeight: 1; }

        TextButton #JoinShadowButton {
          Text: "Join Iron Legion";
          Anchor: (Height: 44);
          Style: $S.@IronLegionButtonStyle;
        }
      }
    }

    // Warning footer
    Group {
      Anchor: (Height: 36);
      LayoutMode: CenterMiddle;

      Label #Warning {
        Text: "This choice is permanent!";
        Style: (FontSize: 14, TextColor: #ff5555, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
      }
    }
  }
}
