// Invite Row Template - Card-style invite entry
// Appended to #InvitationsList

$C = "../Common.ui";
$S = "Styles.ui";

Group {
  Anchor: (Height: 80, Bottom: 8);
  Background: #1a2a3a(0.9);
  LayoutMode: Top;
  Padding: (Left: 14, Right: 14, Top: 10, Bottom: 10);

  // Top row: Guild name + timestamp
  Group {
    LayoutMode: Left;
    Anchor: (Height: 24);

    Label #GuildName {
      Text: "Guild Name";
      FlexWeight: 1;
      Style: (FontSize: 16, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
    }

    Label #InviteTimestamp {
      Text: "";
      Anchor: (Width: 100);
      Style: (FontSize: 11, TextColor: #666666, RenderBold: false, HorizontalAlignment: End, VerticalAlignment: Center);
    }
  }

  // Middle row: Inviter name
  Group {
    LayoutMode: Left;
    Anchor: (Height: 20);

    Label #InviterName {
      Text: "Invited by: Player";
      FlexWeight: 1;
      Style: (FontSize: 12, TextColor: #96a9be, RenderBold: false, VerticalAlignment: Center);
    }
  }

  // Bottom row: Action buttons
  Group {
    LayoutMode: Left;
    Anchor: (Height: 26);

    Group { FlexWeight: 1; }

    TextButton #AcceptButton {
      Text: "ACCEPT";
      Anchor: (Width: 90, Height: 26);
      Style: $S.@SmallSuccessButtonStyle;
    }

    Group { Anchor: (Width: 8); }

    TextButton #DeclineButton {
      Text: "DECLINE";
      Anchor: (Width: 90, Height: 26);
      Style: $S.@SmallDangerButtonStyle;
    }
  }
}
