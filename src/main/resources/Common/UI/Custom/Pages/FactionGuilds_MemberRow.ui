$C = "../Common.ui";
$S = "Styles.ui";

// Guild Member Row Template - Appended to MembersList in Guild Management

Group {
  Anchor: (Height: 48, Bottom: 4);
  Background: #1a2a3a(0.8);
  LayoutMode: Left;
  Padding: (Left: 12, Right: 12);

  // Online indicator dot
  Group #OnlineIndicator {
    Anchor: (Width: 8, Height: 8);
    Background: #757575;
  }

  Group { Anchor: (Width: 10); }

  // Player name
  Label #PlayerName {
    Text: "Player Name";
    Anchor: (Width: 150);
    Style: (FontSize: 14, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
  }

  // Role badge
  Label #RoleBadge {
    Text: "[Member]";
    Anchor: (Width: 100);
    Style: (FontSize: 12, TextColor: #81C784, RenderBold: true, VerticalAlignment: Center);
  }

  Group { FlexWeight: 1; }

  // Action buttons (visible only for manageable members)
  Group #ActionButtons {
    LayoutMode: Left;
    Visible: true;

    TextButton #PromoteButton {
      Text: "Promote";
      Anchor: (Width: 72, Height: 28);
      Style: $S.@SmallSuccessButtonStyle;
      Visible: true;
    }

    Group { Anchor: (Width: 4); }

    TextButton #DemoteButton {
      Text: "Demote";
      Anchor: (Width: 72, Height: 28);
      Style: $S.@SmallPrimaryButtonStyle;
      Visible: true;
    }

    Group { Anchor: (Width: 4); }

    TextButton #KickButton {
      Text: "Kick";
      Anchor: (Width: 52, Height: 28);
      Style: $S.@SmallDangerButtonStyle;
    }
  }
}
