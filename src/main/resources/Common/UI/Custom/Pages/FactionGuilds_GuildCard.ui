// Guild Card Template - Appended to GuildsList
// Dark card with accent left border effect

$C = "../Common.ui";
$S = "Styles.ui";

Group {
  Anchor: (Height: 70, Bottom: 6);
  LayoutMode: Left;

  // Left accent bar
  Group {
    Anchor: (Width: 4);
    Background: #4FC3F7(0.6);
  }

  // Card content
  Group {
    FlexWeight: 1;
    Background: #1a2a3a(0.8);
    LayoutMode: Top;
    Padding: (Left: 14, Right: 14, Top: 10, Bottom: 10);

    // Top row: name + join button
    Group {
      LayoutMode: Left;
      Anchor: (Height: 26);

      Label #GuildName {
        Text: "Guild Name";
        FlexWeight: 1;
        Style: (FontSize: 16, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
      }

      TextButton #RequestJoinButton {
        Text: "Request Join";
        Anchor: (Width: 100, Height: 24);
        Style: $S.@SmallPrimaryButtonStyle;
      }
    }

    // Bottom row: stats
    Group {
      LayoutMode: Left;
      Anchor: (Height: 20, Top: 4);

      Label #MembersLabel {
        Text: "Members: 0";
        Anchor: (Width: 120);
        Style: (FontSize: 12, TextColor: #4FC3F7, RenderBold: false, VerticalAlignment: Center);
      }

      Label #PowerLabel {
        Text: "Power: 0";
        Anchor: (Width: 120);
        Style: (FontSize: 12, TextColor: #81C784, RenderBold: false, VerticalAlignment: Center);
      }
    }
  }
}
