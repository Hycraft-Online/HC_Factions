$C = "../Common.ui";

// Guild Card Template - Appended to GuildsList

@JoinButtonStyle = TextButtonStyle(
  Default: (Background: #1976d2, LabelStyle: (FontSize: 12, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #1e88e5, LabelStyle: (FontSize: 12, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #1565c0, LabelStyle: (FontSize: 12, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Sounds: $C.@ButtonSounds,
);

Group {
  Anchor: (Height: 80, Bottom: 8);
  Background: #1b2532(0.8);
  LayoutMode: Top;
  Padding: (Full: 12);

  Group {
    LayoutMode: Left;
    Anchor: (Height: 24);

    Label #GuildName {
      Text: "Guild Name";
      FlexWeight: 1;
      Style: (FontSize: 18, TextColor: #ffffff, RenderBold: true);
    }

    TextButton #RequestJoinButton {
      Text: "Request Join";
      Anchor: (Width: 100);
      Style: @JoinButtonStyle;
    }
  }

  Group { Anchor: (Height: 8); }

  Group {
    LayoutMode: Left;
    Anchor: (Height: 20);

    Label #MembersLabel {
      Text: "Members: 0";
      Anchor: (Width: 120);
      Style: (FontSize: 14, TextColor: #4FC3F7, RenderBold: false);
    }

    Label #PowerLabel {
      Text: "Power: 0";
      Anchor: (Width: 120);
      Style: (FontSize: 14, TextColor: #81C784, RenderBold: false);
    }
  }
}
