// FactionGuilds Guild Browser - Polished layout with search
// Uses centralized Styles.ui

$C = "../Common.ui";
$S = "Styles.ui";

$C.@PageOverlay {
  Group {
    Anchor: (Width: 700, Height: 520);
    Background: #0a1119(0.98);
    LayoutMode: Top;

    // === Navigation Bar ===
    Group {
      Anchor: (Height: 45);
      Background: #16212f;
      LayoutMode: Left;

      Group {
        Anchor: (Width: 200, Height: 45);
        LayoutMode: Left;
        Padding: (Left: 16);

        Label {
          Text: "Browse Guilds";
          Style: (FontSize: 18, TextColor: #4FC3F7, RenderBold: true, VerticalAlignment: Center);
        }
      }

      Group { FlexWeight: 1; }

      Group {
        LayoutMode: Left;
        Padding: (Right: 12);

        TextButton #CreateGuildButton {
          Text: "Create Guild";
          Anchor: (Width: 100, Height: 32);
          Style: $S.@SmallSuccessButtonStyle;
        }

        Group { Anchor: (Width: 8); }

        TextButton #BackButton {
          Text: "Back";
          Anchor: (Width: 70, Height: 32);
          Style: $S.@SmallPrimaryButtonStyle;
        }
      }
    }

    // === Main Content ===
    Group {
      FlexWeight: 1;
      LayoutMode: Top;
      Padding: (Left: 24, Right: 24, Top: 14, Bottom: 14);

      // Header with faction name
      Label #FactionHeader {
        Text: "Guilds in Faction";
        Anchor: (Height: 30, Bottom: 10);
        Style: (FontSize: 18, TextColor: #ffffff, RenderBold: true);
      }

      // Separator
      Group {
        Anchor: (Height: 1, Bottom: 10);
        Background: #4FC3F7(0.3);
      }

      // No Guilds Message
      Label #NoGuildsMessage {
        Text: "No guilds in your faction yet. Be the first to create one!";
        Anchor: (Height: 30);
        Style: (FontSize: 14, TextColor: #96a9be, RenderBold: false);
        Visible: true;
      }

      // Scrollable guild list
      Group #GuildsContainer {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;

        Group #GuildsList {
          LayoutMode: Top;
          Padding: (Right: 8);
        }
      }
    }
  }
}
