// Join Request Row Template - Card-style request entry
// Used in both the Invitations page (sent requests) and GuildManagement (incoming requests)

$C = "../Common.ui";
$S = "Styles.ui";

Group {
  Anchor: (Height: 56, Bottom: 6);
  Background: #1a2a3a(0.9);
  LayoutMode: Left;
  Padding: (Left: 14, Right: 14, Top: 10, Bottom: 10);

  // Player name
  Label #PlayerName {
    Text: "PlayerName";
    FlexWeight: 1;
    Style: (FontSize: 14, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
  }

  // Timestamp
  Label #RequestTimestamp {
    Text: "";
    Anchor: (Width: 100);
    Style: (FontSize: 11, TextColor: #666666, RenderBold: false, HorizontalAlignment: End, VerticalAlignment: Center);
  }

  Group { Anchor: (Width: 12); }

  // Action buttons
  Group #ActionButtons {
    LayoutMode: Left;

    TextButton #AcceptButton {
      Text: "ACCEPT";
      Anchor: (Width: 80, Height: 30);
      Style: $S.@SmallSuccessButtonStyle;
    }

    Group { Anchor: (Width: 6); }

    TextButton #DeclineButton {
      Text: "DENY";
      Anchor: (Width: 70, Height: 30);
      Style: $S.@SmallDangerButtonStyle;
    }
  }
}
